# === VARIABLES D'ENVIRONNEMENT — IBIG PARTNERS ===
# Copiez ce fichier en .env et remplissez les valeurs.

# --- Base de données ---
# Développement (SQLite)
DATABASE_PROVIDER="sqlite"
DATABASE_URL="file:./dev.db"

# Production (PostgreSQL — exemple Supabase)
# DATABASE_PROVIDER="postgresql"
# DATABASE_URL="postgresql://postgres:[MOT_DE_PASSE]@db.[REF].supabase.co:5432/postgres"

# --- Authentification ---
# Générer avec : openssl rand -base64 32
AUTH_SECRET="CHANGER_CE_SECRET_EN_PRODUCTION"

# --- URL publique ---
NEXT_PUBLIC_SITE_URL="https://ibigpartners.com"

# --- Email transactionnel (Resend — https://resend.com) ---
# 1. Créer un compte sur resend.com (gratuit jusqu'à 3 000 emails/mois)
# 2. Vérifier votre domaine ibigpartners.com dans le dashboard Resend
# 3. Copier la clé API ci-dessous
# Sans cette clé, les emails sont seulement loggués en console (mode dev).
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="IBIG PARTNERS <noreply@ibigpartners.com>"

# --- Support ---
SUPPORT_EMAIL="support@ibigpartners.com"

# --- Paiements (Moneroo — https://moneroo.io) ---
# Moneroo agrège : Orange Money CI, Wave, MTN MoMo, Moov Money, etc.
# 1. Créer un compte sur moneroo.io
# 2. Récupérer la clé secrète dans Dashboard > API Keys
# 3. Configurer l'URL du webhook : https://ibigpartners.com/api/moneroo/webhook
# 4. Copier le secret de signature du webhook (Dashboard > Webhooks)
MONEROO_SECRET_KEY="sk_live_xxxxxxxxxxxxxxxxxxxx"
MONEROO_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxx"
