// IBIG PARTNERS — Programme d'Affiliation Multi-Niveaux
// Supporte SQLite (dev) et PostgreSQL (production) via DATABASE_URL.
// On utilise des String partout (pas d'enum Prisma) pour conserver la compatibilite
// cross-provider. Les valeurs sont validees par src/lib/constants.ts.
// Les montants sont en FCFA, stockes en entiers (le FCFA n'a pas de centimes).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String  @id @default(cuid())
  code         String  @unique // identifiant d'affiliation, ex: AFF-KOFFI-001
  firstName    String
  lastName     String
  email        String  @unique
  phone        String
  passwordHash String
  role         String  @default("PARTNER") // PARTNER | ADMIN | SUPERADMIN
  status       String  @default("STARTER") // STARTER | SILVER | GOLD | MASTER | ELITE
  active       Boolean @default(true)
  approved     Boolean @default(false) // validation manuelle des inscriptions

  // KYC — verification du compte
  partnerType        String  @default("INDIVIDUAL") // INDIVIDUAL | COMPANY
  verificationStatus String  @default("NONE")       // NONE | SUBMITTED | VERIFIED | REJECTED

  // Paiement
  payoutMethod  String  @default("ORANGE_MONEY") // ORANGE_MONEY | WAVE | MTN_MOMO | BANK | PAYPAL | WESTERN_UNION
  payoutDetail  String? // numero mobile money ou IBAN
  minPayout     Int     @default(5000) // seuil declenchement paiement en FCFA
  city          String?

  // Parrainage : structure du reseau multi-niveaux
  sponsorId String?
  sponsor   User?   @relation("Referral", fields: [sponsorId], references: [id])
  referrals User[]  @relation("Referral")

  links            AffiliateLink[]
  sales            Sale[]
  commissions      Commission[]
  payouts          Payout[]
  opportunities    Opportunity[]
  prospects        Prospect[]
  notifications    Notification[]
  tickets          Ticket[]
  ticketMessages   TicketMessage[]    @relation("TicketAuthor")
  auditLogs        AuditLog[]
  otpCode          OtpCode?
  verification     VerificationRequest?

  createdAt DateTime @default(now())
}

// KYC — dossier de verification identite / entreprise
model VerificationRequest {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])
  type   String // INDIVIDUAL | COMPANY
  status String @default("PENDING") // PENDING | APPROVED | REJECTED

  reviewedAt  DateTime?
  reviewedBy  String?   // id de l'admin
  reviewNote  String?   // motif de rejet ou commentaire

  // ─── Particulier ───────────────────────────────────────────
  fullName      String? // nom et prenoms etat civil
  idType        String? // CIN | PASSEPORT | PERMIS | AUTRE
  idNumber      String?
  cvText        String? // CV en texte libre
  country       String?
  city          String?
  profession    String?
  whatsapp      String?
  secondPhone   String?
  contact1Name  String?
  contact1Phone String?
  contact2Name  String?
  contact2Phone String?

  // ─── Entreprise ────────────────────────────────────────────
  companyName     String?
  rccm            String? // registre de commerce
  nif             String?
  compteContrib   String? // compte contribuable
  legalRep        String? // representant legal
  legalRepTitle   String? // DG | Gérant | PDG …
  companyCountry  String?
  companyCity     String?
  companyAddress  String?
  companyEmail    String?
  companyWhatsapp String?
  companyPhone2   String?

  // ─── Coordonnees bancaires / paiement ──────────────────────
  payoutMethod    String? // methode preferee
  mobileMoneyNum  String? // Orange Money / Wave / MTN MoMo
  paypalEmail     String?
  rib             String?
  bankName        String?
  bankCountry     String?
  swift           String?
  iban            String?
  westernUnionName String?

  submittedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Branch {
  id              String  @id @default(cuid())
  name            String
  slug            String  @unique
  tagline         String
  description     String
  offerType       String
  commissionModel String
  active          Boolean @default(true)
  order           Int     @default(0)

  products Product[]
  kits     MarketingKit[]
}

model Product {
  id          String  @id @default(cuid())
  branchId    String
  branch      Branch  @relation(fields: [branchId], references: [id])
  name        String
  slug        String  @unique
  description String?
  price       Int     @default(0) // prix de reference FCFA
  pricingType String // MONTHLY_SUB | ANNUAL_SUB | COURSE | SERVICE | PRODUCT
  rate        Int     @default(8) // taux N1 (%) pour SERVICE/PRODUCT (sinon table standard)
  siteUrl     String? // ex: scolaby.com
  active      Boolean @default(true)

  links AffiliateLink[]
  sales Sale[]
  kits  MarketingKit[]
}

model AffiliateLink {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  code      String   // ex: AFF-KOFFI-001 (code du partenaire, partage entre ses produits)
  clicks    Int      @default(0)
  createdAt DateTime @default(now())

  clickLogs Click[]

  @@unique([userId, productId])
}

model Click {
  id        String        @id @default(cuid())
  linkId    String
  link      AffiliateLink @relation(fields: [linkId], references: [id])
  ip        String?
  userAgent String?
  createdAt DateTime      @default(now())
}

model Sale {
  id            String   @id @default(cuid())
  reference     String   @unique
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  sellerId      String // partenaire vendeur direct (niveau 1 de la vente)
  seller        User     @relation(fields: [sellerId], references: [id])
  customerName  String
  customerPhone String?
  amount        Int // montant FCFA paye par le client (par periode si mensuel)
  pricingType   String // snapshot du type au moment de la vente
  status        String   @default("PENDING") // PENDING | CONFIRMED | CANCELLED
  monthsPaid    Int      @default(1) // nb de mois encaisses (abonnements mensuels)
  createdAt     DateTime @default(now())

  commissions Commission[]
}

model Commission {
  id         String  @id @default(cuid())
  saleId     String
  sale       Sale    @relation(fields: [saleId], references: [id])
  userId     String
  user       User    @relation(fields: [userId], references: [id])
  level      Int // 1 | 2 | 3
  monthIndex Int     @default(1) // 1..4 pour les abonnements mensuels, 1 sinon
  rate       Float // taux effectif applique (bonus de statut inclus)
  amount     Int
  status     String  @default("PENDING") // PENDING | VALIDATED | PAID
  payoutId   String?
  payout     Payout? @relation(fields: [payoutId], references: [id])

  createdAt DateTime @default(now())

  @@unique([saleId, userId, level, monthIndex])
}

model Payout {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  amount        Int
  method        String
  status        String    @default("PENDING") // PENDING | PROCESSING | PAID
  reference     String?
  receiptNumber String?   // numero de recu ex: IBIG-PAY-2024-0001
  fees          Int       @default(0) // frais deduits (international)
  netAmount     Int?      // amount - fees
  scheduledDate DateTime? // date prevue de paiement
  createdAt     DateTime  @default(now())
  paidAt        DateTime?

  commissions Commission[]
}

model Opportunity {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  title          String
  description    String
  estimatedValue Int      @default(0)
  status         String   @default("NEW") // NEW | IN_PROGRESS | WON | LOST
  handler        String?
  createdAt      DateTime @default(now())
}

model Prospect {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  name      String
  contact   String?
  productId String?
  status    String   @default("CONTACTED") // CONTACTED | DEMO | CONVERTED | LOST
  note      String?
  createdAt DateTime @default(now())
}

model MarketingKit {
  id        String   @id @default(cuid())
  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  title     String
  type      String // VISUAL | ARGUMENT | VIDEO
  content   String // texte de l'argumentaire ou URL du visuel/video
  minStatus String   @default("STARTER")
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String? // null = annonce diffusee a tous
  user      User?    @relation(fields: [userId], references: [id])
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Setting {
  key   String @id
  value String
}

// --- Option 5 : Analytics (clics enrichis) ---
// Le modèle Click existant est déjà utilisé ; on ajoute une vue agrégée via des requêtes.

// --- Option 8 : Tickets support ---
model Ticket {
  id       String          @id @default(cuid())
  userId   String
  user     User            @relation(fields: [userId], references: [id])
  subject  String
  status   String          @default("OPEN") // OPEN | IN_PROGRESS | CLOSED
  priority String          @default("NORMAL") // LOW | NORMAL | HIGH | URGENT
  messages TicketMessage[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id])
  authorId  String
  author    User     @relation("TicketAuthor", fields: [authorId], references: [id])
  body      String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
}

// --- Option 9 : Audit log ---
model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String   // ex: APPROVE_PARTNER, VALIDATE_COMMISSIONS, CREATE_SALE…
  target    String?  // identifiant de l'entité cible (id de partenaire, vente, etc.)
  detail    String?  // JSON ou texte libre
  createdAt DateTime @default(now())
}

// --- Option 10 : 2FA OTP email ---
model OtpCode {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  code      String   // 6 chiffres hashés
  expiresAt DateTime
  createdAt DateTime @default(now())
}
